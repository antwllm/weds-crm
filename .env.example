# ===========================================
# Weds CRM - Variables d'environnement
# ===========================================

# Base de donnees PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/weds_crm

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Session Express
SESSION_SECRET=change-this-to-a-secure-random-string

# Twilio SMS (envoi SMS aux prospects)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+33xxxxxxxxx

# Free Mobile SMS (alertes admin)
FREE_MOBILE_USER=your-free-mobile-user-id
FREE_MOBILE_PASS=your-free-mobile-api-key

# Google Cloud Storage (stockage vCards)
GCS_BUCKET_NAME=weds-crm-vcards

# Sentry (suivi des erreurs - optionnel en dev)
SENTRY_DSN=

# Gmail Pub/Sub
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications

# Emails
ADMIN_EMAIL=contact@weds.fr
ALLOWED_USER_EMAIL=your-google-email@gmail.com

# Application
NODE_ENV=development
PORT=8080

# Pipedrive CRM
PIPEDRIVE_API_TOKEN=your-pipedrive-api-token
PIPEDRIVE_COMPANY_DOMAIN=weds

# OpenRouter AI (generation de brouillons IA)
OPENROUTER_API_KEY=your-openrouter-api-key

# WhatsApp Business API (via Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-whatsapp-webhook-verify-token
WHATSAPP_APP_SECRET=your-whatsapp-app-secret-for-signature-verification
